# ─────────────────────────────────────────────────────────────────────────────
# LinkFlow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=LinkFlow
DEBUG=true

# Security — MUST be changed in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# SQLite (local development):
# DATABASE_URL=sqlite:///./linkflow.db
# PostgreSQL (docker / production):
DATABASE_URL=postgresql://linkflow:securepassword@localhost:5432/linkflow

# CORS — Origins allowed to call the API (JSON array string)
CORS_ORIGINS=["http://localhost:3000"]

# Base URL — used to build short link URLs in responses
BASE_URL=http://localhost:8000

# Google OAuth — "Sign in with Google"
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add http://localhost:3000 to Authorized JavaScript origins
# 4. Paste the Client ID below (looks like: 123456789-xxx.apps.googleusercontent.com)
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=
